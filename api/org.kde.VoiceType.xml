<!DOCTYPE node PUBLIC
          "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
          "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">

<node>
    <interface name="org.kde.VoiceType">

        <annotation
            name="org.freedesktop.DBus.Property.EmitsChangedSignal"
            value="true"/>

        <method name="StartRecording"/>

        <method name="StopRecording"/>

        <property
            name="VoiceActivation"
            type="b"
            access="readwrite"/>

        <property
            name="Language"
            type="s"
            access="readwrite"/>

        <!--
        Status values:

        0 = Idle
        1 = LoadingModel
        2 = WaitingForActivation
        3 = Recording
        4 = Transcribing
        5 = InsertingText
        6 = Error
        -->

        <property
            name="Status"
            type="u"
            access="read"/>

        <property
            name="TranscribedText"
            type="s"
            access="read"/>

        <property
            name="Provider"
            type="s"
            access="read"/>

        <property
            name="MaximumRecordingDurationSeconds"
            type="u"
            access="read"/>

        <property
            name="LastError"
            type="s"
            access="read"/>

    </interface>
</node>
